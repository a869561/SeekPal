ENVIRONMENT=development
PORT=3000
MONGO_URI=mongodb://localhost:27017
MONGO_DB=seekpal
JWT_SECRET=seekpal_secret_change_me
JWT_EXPIRES_MINUTES=480
DEFAULT_PASSWORD=seekpal
CORS_ORIGIN=http://localhost:5173

# RAG
OLLAMA_URL=http://localhost:11434
QDRANT_PATH=./qdrant_data
LLM_MODEL=llama3.2:3b
EMBEDDING_MODEL=bge-m3
RAG_CHUNK_SIZE=512
RAG_CHUNK_OVERLAP=64
RAG_TOP_K=5
RAG_EMBED_BATCH=32

# Vision model para captioning de imágenes (CPU por defecto, sin VRAM)
# Recomendado: qwen2.5-vl:3b  (ollama pull qwen2.5-vl:3b)
# Fallback:    moondream       (más ligero, peor calidad)
SEEKPAL_VISION_MODEL=qwen2.5-vl:3b
